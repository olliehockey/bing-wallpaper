#!/bin/zsh
#
# bing-wallpaper-macos
#
# Downloads Bing's daily wallpaper and sets it as the macOS desktop wallpaper.
#
# This is a macOS-specific adaptation of the general idea behind GNOME's
# Bing Wallpaper extension. It is not a direct port of that extension and does
# not reuse its codebase.
#
# The script is designed to be run repeatedly by launchd. It records success
# only after the wallpaper has actually been set, so failures can be retried.
#
# Usage:
#   bing-wallpaper          Run the updater normally
#   bing-wallpaper enable   Enable automatic updates
#   bing-wallpaper disable  Disable automatic updates
#   bing-wallpaper status   Show current status
#   bing-wallpaper info     Show current Bing image information

set -euo pipefail

DEFAULT_MARKET="${BING_MARKET:-en-GB}"
WALLPAPER_DIR="$HOME/Pictures/Bing Wallpaper"
JSON_FILE="$WALLPAPER_DIR/latest.json"
SUCCESS_FILE="$WALLPAPER_DIR/.last-success-date"
DISABLED_FILE="$WALLPAPER_DIR/.disabled"
MARKET_FILE="$WALLPAPER_DIR/.market"
LAUNCHD_LABEL="com.bing-wallpaper-macos.agent"

mkdir -p "$WALLPAPER_DIR"

if [[ -f "$MARKET_FILE" ]]; then
  MARKET="$(cat "$MARKET_FILE" 2>/dev/null | tr -d '[:space:]')"
  if [[ -z "$MARKET" ]]; then
    MARKET="$DEFAULT_MARKET"
  fi
else
  MARKET="$DEFAULT_MARKET"
fi

get_desktoppr_bin() {
  if [[ -x /usr/local/bin/desktoppr ]]; then
    echo "/usr/local/bin/desktoppr"
  elif [[ -x /opt/homebrew/bin/desktoppr ]]; then
    echo "/opt/homebrew/bin/desktoppr"
  elif command -v desktoppr >/dev/null 2>&1; then
    command -v desktoppr
  fi
}

get_current_wallpaper() {
  local desktoppr_bin
  desktoppr_bin="$(get_desktoppr_bin || true)"

  if [[ -n "$desktoppr_bin" ]]; then
    "$desktoppr_bin" 2>/dev/null | head -n 1 || true
    return 0
  fi

  /usr/bin/osascript -e 'tell application "System Events" to get picture of current desktop' 2>/dev/null || true
}

set_wallpaper() {
  local image_file="$1"
  local desktoppr_bin
  desktoppr_bin="$(get_desktoppr_bin || true)"

  if [[ -n "$desktoppr_bin" ]]; then
    "$desktoppr_bin" "$image_file"
    sleep 1

    if "$desktoppr_bin" | grep -Fxq "$image_file"; then
      return 0
    fi

    echo "desktoppr did not verify the wallpaper path. Falling back to AppleScript."
  fi

  BING_WALLPAPER_PATH="$image_file" /usr/bin/osascript <<'APPLESCRIPT'
set wallpaperPath to system attribute "BING_WALLPAPER_PATH"

tell application "System Events"
  repeat with d in desktops
    set picture of d to wallpaperPath
  end repeat
end tell
APPLESCRIPT

  sleep 1

  local current_wallpaper
  current_wallpaper="$(get_current_wallpaper || true)"

  if [[ "$current_wallpaper" == "$image_file" ]]; then
    return 0
  fi

  echo "Wallpaper setter did not verify."
  echo "Expected: $image_file"
  echo "Current:  $current_wallpaper"
  return 1
}


write_info_file() {
  local json_file="$1"
  local end_date="$2"
  local image_file="$3"

  if [[ ! -f "$json_file" || -z "$end_date" ]]; then
    return 0
  fi

  local title copyright copyright_link info_file

  title="$(/usr/bin/plutil -extract images.0.title raw -o - "$json_file" 2>/dev/null || true)"
  copyright="$(/usr/bin/plutil -extract images.0.copyright raw -o - "$json_file" 2>/dev/null || true)"
  copyright_link="$(/usr/bin/plutil -extract images.0.copyrightlink raw -o - "$json_file" 2>/dev/null || true)"

  info_file="$WALLPAPER_DIR/bing-$end_date-info.txt"

  cat > "$info_file" <<INFO
Bing wallpaper of the day

Date: $end_date
Market: $MARKET
Image file: $image_file

Title:
${title:-Unavailable}

Copyright:
${copyright:-Unavailable}

Source:
${copyright_link:-Unavailable}
INFO
}

get_current_info_file() {
  local end_date info_file

  if [[ -f "$JSON_FILE" ]]; then
    end_date="$(/usr/bin/plutil -extract images.0.enddate raw -o - "$JSON_FILE" 2>/dev/null || true)"
    if [[ -n "$end_date" ]]; then
      info_file="$WALLPAPER_DIR/bing-$end_date-info.txt"
      if [[ -f "$info_file" ]]; then
        echo "$info_file"
        return 0
      fi
    fi
  fi

  local info_files=("$WALLPAPER_DIR"/bing-*-info.txt(N))
  if (( ${#info_files[@]} > 0 )); then
    echo "${info_files[-1]}"
  fi
}

print_usage() {
  cat <<USAGE
Usage:
  bing-wallpaper [command]

Commands:
  bing-wallpaper
      Run the updater normally.

  bing-wallpaper status
      Show whether updates are enabled, the current market, the latest recorded
      Bing image date, the current wallpaper path, and the info file path.

  bing-wallpaper info
      Print the current Bing image information note.

  bing-wallpaper market
      Show the current Bing market.

  bing-wallpaper market MARKET
      Change the Bing market, clear the success marker, and request an
      immediate updater run.

  bing-wallpaper market reset
      Reset to the default market.

  bing-wallpaper disable
      Pause automatic wallpaper updates without uninstalling.

  bing-wallpaper enable
      Re-enable updates and request an immediate updater run.

USAGE
}


print_market_usage() {
  cat <<USAGE
Usage:
  bing-wallpaper market
  bing-wallpaper market MARKET
  bing-wallpaper market reset

Show or change the Bing market.

Examples:
  bing-wallpaper market
  bing-wallpaper market en-GB
  bing-wallpaper market en-US
  bing-wallpaper market fr-FR
  bing-wallpaper market de-DE
  bing-wallpaper market reset

Market format:
  language-REGION

Examples:
  en-GB   United Kingdom English
  en-US   United States English
  fr-FR   France French
  de-DE   Germany German
  ja-JP   Japan Japanese

Changing market clears the last successful update marker and requests an
immediate updater run.
USAGE
}

print_info_usage() {
  cat <<USAGE
Usage:
  bing-wallpaper info

Print the current Bing image information note.

The note is stored beside the downloaded wallpaper using this pattern:

  bing-YYYYMMDD-info.txt

Example:

  ~/Pictures/Bing Wallpaper/bing-20260623-info.txt

The note contains the date, market, image file path, title, copyright/credit,
and source link from Bing metadata.
USAGE
}


print_status_usage() {
  cat <<USAGE
Usage:
  bing-wallpaper status

Show the current updater state.

It reports:
  status enabled/disabled
  current market
  last successful update date
  latest recorded Bing image date
  current wallpaper path
  image info file path
USAGE
}

print_enable_usage() {
  cat <<USAGE
Usage:
  bing-wallpaper enable

Re-enable automatic wallpaper updates.

This removes the disabled marker and requests an immediate scheduler run.

On macOS, this requests a LaunchAgent kickstart.

Use this after:

  bing-wallpaper disable
USAGE
}

print_disable_usage() {
  cat <<USAGE
Usage:
  bing-wallpaper disable

Pause automatic wallpaper updates without uninstalling.

When disabled:
  scheduled runs exit immediately
  the current wallpaper is left unchanged
  the LaunchAgent remains installed

Re-enable with:

  bing-wallpaper enable
USAGE
}

case "${1:-run}" in
  enable)
    if [[ "${2:-}" == "-h" || "${2:-}" == "-help" || "${2:-}" == "--help" || "${2:-}" == "help" ]]; then
      print_enable_usage
      exit 0
    fi

    rm -f "$DISABLED_FILE"
    echo "Bing wallpaper updates enabled."
    echo "Triggering a launchd run now."

    if launchctl print "gui/$(id -u)/$LAUNCHD_LABEL" >/dev/null 2>&1; then
      launchctl kickstart -k "gui/$(id -u)/$LAUNCHD_LABEL"
      echo "LaunchAgent triggered."
      exit 0
    fi

    echo "LaunchAgent is not currently loaded. Running updater directly instead."
    exec "$0"
    ;;

  disable)
    if [[ "${2:-}" == "-h" || "${2:-}" == "-help" || "${2:-}" == "--help" || "${2:-}" == "help" ]]; then
      print_disable_usage
      exit 0
    fi

    /bin/date -u +"%Y-%m-%dT%H:%M:%SZ" > "$DISABLED_FILE"
    echo "Bing wallpaper updates disabled."
    echo "Current wallpaper has not been changed."
    echo "Run this to re-enable:"
    echo "  bing-wallpaper enable"
    exit 0
    ;;

  market)
    if [[ "${2:-}" == "-h" || "${2:-}" == "-help" || "${2:-}" == "--help" || "${2:-}" == "help" ]]; then
      print_market_usage
      exit 0
    fi

    if [[ $# -lt 2 ]]; then
      echo "Current market: $MARKET"
      echo
      echo "Change market with:"
      echo "  bing-wallpaper market en-US"
      echo "  bing-wallpaper market en-GB"
      echo
      echo "Reset to default with:"
      echo "  bing-wallpaper market reset"
      exit 0
    fi

    NEW_MARKET="$2"

    if [[ "$NEW_MARKET" == "reset" ]]; then
      rm -f "$MARKET_FILE"
      MARKET="$DEFAULT_MARKET"
      echo "Market reset to default: $MARKET"
    elif [[ ! "$NEW_MARKET" == [a-z][a-z]-[A-Z][A-Z] ]]; then
      echo "Invalid market: $NEW_MARKET"
      echo "Expected format like en-GB, en-US, fr-FR, de-DE."
      exit 2
    else
      echo "$NEW_MARKET" > "$MARKET_FILE"
      MARKET="$NEW_MARKET"
      echo "Market set to: $MARKET"
    fi

    rm -f "$SUCCESS_FILE"
    echo "Cleared last successful update marker so the new market can update immediately."
    echo "Requesting an updater run now."

    if launchctl print "gui/$(id -u)/$LAUNCHD_LABEL" >/dev/null 2>&1; then
      nohup launchctl kickstart -k "gui/$(id -u)/$LAUNCHD_LABEL" >/dev/null 2>&1 &
      echo "LaunchAgent trigger requested."
      exit 0
    fi

    echo "LaunchAgent is not currently loaded. Running updater directly instead."
    exec "$0"
    ;;

  info)
    if [[ "${2:-}" == "-h" || "${2:-}" == "-help" || "${2:-}" == "--help" || "${2:-}" == "help" ]]; then
      print_info_usage
      exit 0
    fi

    INFO_FILE="$(get_current_info_file)"

    if [[ -z "$INFO_FILE" && -f "$JSON_FILE" ]]; then
      INFO_END_DATE="$(/usr/bin/plutil -extract images.0.enddate raw -o - "$JSON_FILE" 2>/dev/null || true)"

      if [[ -n "$INFO_END_DATE" ]]; then
        INFO_IMAGE=""
        if [[ -f "$WALLPAPER_DIR/bing-$INFO_END_DATE-UHD.jpg" ]]; then
          INFO_IMAGE="$WALLPAPER_DIR/bing-$INFO_END_DATE-UHD.jpg"
        elif [[ -f "$WALLPAPER_DIR/bing-$INFO_END_DATE.jpg" ]]; then
          INFO_IMAGE="$WALLPAPER_DIR/bing-$INFO_END_DATE.jpg"
        fi

        write_info_file "$JSON_FILE" "$INFO_END_DATE" "$INFO_IMAGE"
        INFO_FILE="$(get_current_info_file)"
      fi
    fi

    if [[ -n "$INFO_FILE" && -f "$INFO_FILE" ]]; then
      cat "$INFO_FILE"
      exit 0
    fi

    echo "No Bing wallpaper info file found yet."
    exit 1
    ;;

  status)
    if [[ "${2:-}" == "-h" || "${2:-}" == "-help" || "${2:-}" == "--help" || "${2:-}" == "help" ]]; then
      print_status_usage
      exit 0
    fi

    if [[ -f "$DISABLED_FILE" ]]; then
      echo "Status: disabled"
      echo "Disabled marker: $DISABLED_FILE"
      echo "Disabled since: $(cat "$DISABLED_FILE" 2>/dev/null || echo unknown)"
      echo
      echo "Run this to re-enable:"
      echo "  bing-wallpaper enable"
    else
      echo "Status: enabled"
      echo "Updates are allowed."
    fi

    echo "Current market: $MARKET"

    if [[ -f "$SUCCESS_FILE" ]]; then
      echo "Last successful update: $(cat "$SUCCESS_FILE")"
    else
      echo "Last successful update: none recorded"
    fi

    if [[ -f "$JSON_FILE" ]]; then
      END_DATE="$(/usr/bin/plutil -extract images.0.enddate raw -o - "$JSON_FILE" 2>/dev/null || true)"
      if [[ -n "$END_DATE" ]]; then
        echo "Latest recorded Bing image date: $END_DATE"
      fi
    fi

    CURRENT_WALLPAPER="$(get_current_wallpaper || true)"
    if [[ -n "$CURRENT_WALLPAPER" ]]; then
      echo "Current wallpaper: $CURRENT_WALLPAPER"
    fi

    INFO_FILE="$(get_current_info_file)"
    if [[ -n "$INFO_FILE" ]]; then
      echo "Info file: $INFO_FILE"
    fi

    exit 0
    ;;

  run|"")
    ;;

  -h|-help|--help|help)
    print_usage
    exit 0
    ;;

  *)
    echo "Unknown command: $1"
    echo
    print_usage
    exit 2
    ;;
esac

if [[ -f "$DISABLED_FILE" ]]; then
  echo "Bing wallpaper updates are disabled. Leaving wallpaper unchanged."
  echo "Run this to re-enable:"
  echo "  bing-wallpaper enable"
  exit 0
fi

TODAY="$(/bin/date +%F)"
LAST_SUCCESS="$(cat "$SUCCESS_FILE" 2>/dev/null || true)"

EXPECTED_IMAGE=""

if [[ -f "$JSON_FILE" ]]; then
  EXPECTED_END_DATE="$(/usr/bin/plutil -extract images.0.enddate raw -o - "$JSON_FILE" 2>/dev/null || true)"

  if [[ -n "$EXPECTED_END_DATE" ]]; then
    if [[ -f "$WALLPAPER_DIR/bing-$EXPECTED_END_DATE-UHD.jpg" ]]; then
      EXPECTED_IMAGE="$WALLPAPER_DIR/bing-$EXPECTED_END_DATE-UHD.jpg"
    elif [[ -f "$WALLPAPER_DIR/bing-$EXPECTED_END_DATE.jpg" ]]; then
      EXPECTED_IMAGE="$WALLPAPER_DIR/bing-$EXPECTED_END_DATE.jpg"
    fi
  fi
fi

if [[ "$LAST_SUCCESS" == "$TODAY" && -n "$EXPECTED_IMAGE" ]]; then
  CURRENT_WALLPAPER="$(get_current_wallpaper || true)"

  if [[ "$CURRENT_WALLPAPER" == "$EXPECTED_IMAGE" ]]; then
    write_info_file "$JSON_FILE" "$EXPECTED_END_DATE" "$EXPECTED_IMAGE"
    echo "Wallpaper already successfully updated today ($TODAY). Local image exists and is currently set: $EXPECTED_IMAGE. Leaving as-is."
    exit 0
  fi

  echo "Today's Bing wallpaper exists, but the desktop is not using it. Restoring wallpaper."
  echo "Expected: $EXPECTED_IMAGE"
  echo "Current:  $CURRENT_WALLPAPER"

  if ! set_wallpaper "$EXPECTED_IMAGE"; then
    echo "Could not restore Bing wallpaper. Not marking this run as successful."
    exit 1
  fi

  killall WallpaperAgent 2>/dev/null || true
  echo "$TODAY" > "$SUCCESS_FILE"
  write_info_file "$JSON_FILE" "$EXPECTED_END_DATE" "$EXPECTED_IMAGE"
  echo "Restored wallpaper to $EXPECTED_IMAGE"
  exit 0
fi

if [[ "$LAST_SUCCESS" == "$TODAY" ]]; then
  echo "Today was marked successful, but the local Bing wallpaper file is missing. Re-downloading."
fi

TMP_JSON="$WALLPAPER_DIR/.latest.$$.json"
TMP_IMAGE="$WALLPAPER_DIR/.bing.$$.jpg"

cleanup_tmp() {
  rm -f "$TMP_JSON" "$TMP_IMAGE"
}
trap cleanup_tmp EXIT

API_URL="https://www.bing.com/HPImageArchive.aspx?format=js&uhd=1&idx=0&n=1&mkt=$MARKET"

curl -fsSL --connect-timeout 15 --max-time 60 "$API_URL" -o "$TMP_JSON"

URL_BASE=$(/usr/bin/plutil -extract images.0.urlbase raw -o - "$TMP_JSON")
END_DATE=$(/usr/bin/plutil -extract images.0.enddate raw -o - "$TMP_JSON")

UHD_URL="https://www.bing.com${URL_BASE}_UHD.jpg"
IMAGE_FILE="$WALLPAPER_DIR/bing-$END_DATE-UHD.jpg"

if ! curl -fsSL --connect-timeout 15 --max-time 120 "$UHD_URL" -o "$TMP_IMAGE"; then
  rm -f "$TMP_IMAGE"
  IMAGE_PATH=$(/usr/bin/plutil -extract images.0.url raw -o - "$TMP_JSON")
  IMAGE_URL="https://www.bing.com$IMAGE_PATH"
  IMAGE_FILE="$WALLPAPER_DIR/bing-$END_DATE.jpg"
  curl -fsSL --connect-timeout 15 --max-time 120 "$IMAGE_URL" -o "$TMP_IMAGE"
fi

if ! /usr/bin/sips -g pixelWidth -g pixelHeight "$TMP_IMAGE" >/dev/null 2>&1; then
  echo "Downloaded file was not a valid image. Leaving wallpaper unchanged."
  exit 1
fi

mv "$TMP_JSON" "$JSON_FILE"
mv "$TMP_IMAGE" "$IMAGE_FILE"

if ! set_wallpaper "$IMAGE_FILE"; then
  echo "Wallpaper was downloaded, but macOS did not confirm it was set."
  echo "Not marking today as successful so launchd can retry later."
  exit 1
fi

killall WallpaperAgent 2>/dev/null || true

echo "$TODAY" > "$SUCCESS_FILE"
write_info_file "$JSON_FILE" "$END_DATE" "$IMAGE_FILE"

for old_image in "$WALLPAPER_DIR"/bing-*.jpg(N); do
  if [[ "$old_image" != "$IMAGE_FILE" ]]; then
    rm -f -- "$old_image"
  fi
done

INFO_FILE="$WALLPAPER_DIR/bing-$END_DATE-info.txt"
for old_info in "$WALLPAPER_DIR"/bing-*-info.txt(N); do
  if [[ "$old_info" != "$INFO_FILE" ]]; then
    rm -f -- "$old_info"
  fi
done

echo "Set wallpaper to $IMAGE_FILE"
echo "Marked $TODAY as successfully updated."
echo "Old Bing wallpapers cleaned up."

/usr/bin/sips -g pixelWidth -g pixelHeight "$IMAGE_FILE" 2>/dev/null | tail -n 2
